{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "ecommerce.db",
        "node_modules/better-sqlite3/build/Release/better_sqlite3.node"
      ]
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}